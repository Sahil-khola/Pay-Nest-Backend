{
  "swagger": "2.0",
  "info": {
    "title": "Pay Nest API",
    "description": "REST API for Pay Nest backend supporting authentication, peer-to-peer transfers, wallet operations, and transaction history.",
    "version": "1.0.0",
    "contact": {
      "name": "API Support"
    }
  },
  "host": "localhost:5000",
  "basePath": "/",
  "schemes": ["http"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "JWT token prefixed with 'Bearer '. Example: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
    }
  },
  "parameters": {
    "AuthorizationHeader": {
      "name": "Authorization",
      "in": "header",
      "type": "string",
      "required": true,
      "description": "Bearer token for authenticated endpoints"
    }
  },
  "definitions": {
    "RegisterRequest": {
      "type": "object",
      "required": ["name", "email", "phone", "password"],
      "properties": {
        "name": {
          "type": "string",
          "example": "John Doe",
          "minLength": 2,
          "maxLength": 50
        },
        "email": {
          "type": "string",
          "format": "email",
          "example": "john@example.com",
          "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$"
        },
        "phone": {
          "type": "string",
          "example": "9876543210",
          "pattern": "^\\d{10}$",
          "description": "10-digit mobile number without country code"
        },
        "password": {
          "type": "string",
          "format": "password",
          "example": "StrongPass123!",
          "minLength": 6,
          "maxLength": 50
        }
      }
    },
    "LoginRequest": {
      "type": "object",
      "required": ["email", "password"],
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "example": "john@example.com"
        },
        "password": {
          "type": "string",
          "format": "password",
          "example": "StrongPass123!"
        }
      }
    },
    "MpinRequest": {
      "type": "object",
      "required": ["mpin"],
      "properties": {
        "mpin": {
          "type": "string",
          "example": "1234",
          "pattern": "^\\d{4,6}$",
          "description": "4-6 digit MPIN"
        }
      }
    },
    "SendMoneyRequest": {
      "type": "object",
      "required": ["receiverIdentifier", "amount", "mpin"],
      "properties": {
        "receiverIdentifier": {
          "type": "string",
          "example": "9876543210",
          "description": "Receiver phone number or email"
        },
        "amount": {
          "type": "number",
          "format": "decimal",
          "example": 500.00,
          "minimum": 0.01
        },
        "mpin": {
          "type": "string",
          "example": "1234",
          "pattern": "^\\d{4,6}$"
        }
      }
    },
    "AddMoneyRequest": {
      "type": "object",
      "required": ["amount"],
      "properties": {
        "amount": {
          "type": "number",
          "format": "decimal",
          "example": 1000.00,
          "minimum": 0.01
        }
      }
    },
    "PayBillRequest": {
      "type": "object",
      "required": ["billerName", "amount", "mpin"],
      "properties": {
        "billerName": {
          "type": "string",
          "example": "Electricity Board"
        },
        "amount": {
          "type": "number",
          "format": "decimal",
          "example": 250.00,
          "minimum": 0.01
        },
        "mpin": {
          "type": "string",
          "example": "1234",
          "pattern": "^\\d{4,6}$"
        }
      }
    },
    "ProfileResponse": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string",
          "example": "60d5f3a7b3d2c845f0e4c123"
        },
        "name": {
          "type": "string",
          "example": "John Doe"
        },
        "email": {
          "type": "string",
          "example": "john@example.com"
        },
        "phone": {
          "type": "string",
          "example": "9876543210"
        },
        "walletBalance": {
          "type": "number",
          "format": "decimal",
          "example": 1500.00
        },
        "hasMpin": {
          "type": "boolean",
          "example": true
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "example": "2025-01-15T10:30:00Z"
        }
      }
    },
    "TransactionResponse": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string",
          "example": "60d5f3a7b3d2c845f0e4c456"
        },
        "sender": {
          "type": "string",
          "example": "60d5f3a7b3d2c845f0e4c123"
        },
        "receiver": {
          "type": "string",
          "example": "60d5f3a7b3d2c845f0e4c789"
        },
        "amount": {
          "type": "number",
          "format": "decimal",
          "example": 500.00
        },
        "type": {
          "type": "string",
          "enum": ["send", "receive", "add_money", "pay_bill"],
          "example": "send"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "completed", "failed"],
          "example": "completed"
        },
        "billerName": {
          "type": "string",
          "example": "Electricity Board"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "example": "2025-01-15T10:35:00Z"
        }
      }
    },
    "TransactionHistoryResponse": {
      "type": "object",
      "properties": {
        "transactions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TransactionResponse"
          }
        },
        "total": {
          "type": "integer",
          "example": 42
        },
        "page": {
          "type": "integer",
          "example": 1
        },
        "limit": {
          "type": "integer",
          "example": 10
        }
      }
    },
    "WalletResponse": {
      "type": "object",
      "properties": {
        "walletBalance": {
          "type": "number",
          "format": "decimal",
          "example": 2500.00
        },
        "message": {
          "type": "string",
          "example": "Money added successfully"
        }
      }
    },
    "HealthResponse": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "example": "ok"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "example": "2025-01-15T10:00:00Z"
        }
      }
    },
    "Error": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": {
          "type": "string",
          "example": "Invalid request payload"
        },
        "code": {
          "type": "string",
          "example": "VALIDATION_ERROR"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "example": []
        }
      }
    }
  },
  "paths": {
    "/": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Returns service health status. No authentication required.",
        "security": [],
        "responses": {
          "200": {
            "description": "API is healthy",
            "schema": {
              "$ref": "#/definitions/HealthResponse"
            }
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register a new user",
        "description": "Creates a new user account with name, email, phone, and password.",
        "security": [],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/RegisterRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "User registered successfully",
            "schema": {
              "$ref": "#/definitions/ProfileResponse"
            }
          },
          "400": {
            "description": "Validation error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "409": {
            "description": "User already exists",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Login user",
        "description": "Authenticates a user and returns a JWT bearer token.",
        "security": [],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/LoginRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Login successful",
            "schema": {
              "$ref": "#/definitions/ProfileResponse"
            }
          },
          "401": {
            "description": "Invalid credentials",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      }
    },
    "/api/auth/profile": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Get current user profile",
        "description": "Retrieves the profile of the currently authenticated user.",
        "parameters": [
          {
            "$ref": "#/parameters/AuthorizationHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Profile retrieved successfully",
            "schema": {
              "$ref": "#/definitions/ProfileResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "404": {
            "description": "Profile not found",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      }
    },
    "/api/auth/set-mpin": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Set transaction MPIN",
        "description": "Allows an authenticated user to set or update their MPIN for transactions.",
        "parameters": [
          {
            "$ref": "#/parameters/AuthorizationHeader"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/MpinRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "MPIN set successfully",
            "schema": {
              "$ref": "#/definitions/ProfileResponse"
            }
          },
          "400": {
            "description": "Validation error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      }
    },
    "/api/transaction/send": {
      "post": {
        "tags": ["Transactions"],
        "summary": "Send money to another user",
        "description": "Transfers money from sender's wallet to receiver using MPIN verification.",
        "parameters": [
          {
            "$ref": "#/parameters/AuthorizationHeader"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SendMoneyRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Transaction initiated successfully",
            "schema": {
              "$ref": "#/definitions/TransactionResponse"
            }
          },
          "400": {
            "description": "Validation error or insufficient balance",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "404": {
            "description": "Receiver not found",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      }
    },
    "/api/transactions/history": {
      "get": {
        "tags": ["Transactions"],
        "summary": "Get transaction history",
        "description": "Returns paginated list of transactions for the authenticated user.",
        "parameters": [
          {
            "$ref": "#/parameters/AuthorizationHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction history retrieved",
            "schema": {
              "$ref": "#/definitions/TransactionHistoryResponse"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      }
    },
    "/api/wallet/add-money": {
      "post": {
        "tags": ["Wallet"],
        "summary": "Add money to wallet",
        "description": "Adds funds to the authenticated user's wallet.",
        "parameters": [
          {
            "$ref": "#/parameters/AuthorizationHeader"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/AddMoneyRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Money added successfully",
            "schema": {
              "$ref": "#/definitions/WalletResponse"
            }
          },
          "400": {
            "description": "Validation error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      }
    },
    "/api/wallet/pay-bill": {
      "post": {
        "tags": ["Wallet"],
        "summary": "Pay a bill",
        "description": "Pays a bill using wallet balance with MPIN verification.",
        "parameters": [
          {
            "$ref": "#/parameters/AuthorizationHeader"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/PayBillRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bill paid successfully",
            "schema": {
              "$ref": "#/definitions/TransactionResponse"
            }
          },
          "400": {
            "description": "Validation error or insufficient balance",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "401": {
            "description": "Unauthorized",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "$ref": "#/definitions/Error"
            }
          }
        }
      }
    }
  }
}